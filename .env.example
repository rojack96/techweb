# Environment Configuration
# Copy this file to .env and modify with your values

# ============================================================================
# Docker Registry Configuration
# ============================================================================

# Docker registry URL (default: localhost:5000)
DOCKER_REGISTRY=localhost:5000

# Docker namespace (default: techweb)
DOCKER_NAMESPACE=techweb

# ============================================================================
# Database Configuration (PostGIS)
# ============================================================================

POSTGRES_DB=gis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ============================================================================
# Keycloak Configuration
# ============================================================================

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=password

# ============================================================================
# Application Configuration
# ============================================================================

# Gin mode (debug, release)
GIN_MODE=debug

# JWT Secret
JWT_SECRET=dev-secret-key-change-in-production

# ============================================================================
# Build Configuration
# ============================================================================

# Dry run mode (true/false)
DRY_RUN=false

# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_PORT=6379
